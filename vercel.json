{
  "rewrites": [
    { "source": "/mobile/assets/:path*", "destination": "/mobile/assets/:path*" },
    { "source": "/mobile/images/:path*", "destination": "/mobile/images/:path*" },
    { "source": "/mobile/:path*", "destination": "/mobile/index.html" },
    { "source": "/:path*", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/mobile/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
